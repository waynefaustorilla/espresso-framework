<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{block title}{$app_name}{/block}</title>
  {vite("resources/js/app.js")|noescape}
  {block styles}{/block}
</head>
<body>
  <nav>
    <div class="container">
      <a href="/">{$app_name}</a>
    </div>
  </nav>

  <main>
    <div class="container">
      {block content}{/block}
    </div>
  </main>

  <footer>
    <div class="container">
      &copy; {=date('Y')} {$app_name}
    </div>
  </footer>

  {block scripts}{/block}
</body>
</html>
