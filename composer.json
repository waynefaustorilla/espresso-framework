{
  "name": "espresso/framework",
  "description": "A full-stack PHP 8.4 MVC framework — Espresso",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "doctrine/migrations": "^3.9",
    "doctrine/orm": "^3.6",
    "firebase/php-jwt": "^7.0",
    "laminas/laminas-diactoros": "^3.8",
    "laminas/laminas-httphandlerrunner": "^2.10",
    "latte/latte": "^3.1",
    "league/route": "^6.2",
    "monolog/monolog": "^3.10",
    "php-di/php-di": "^7.1",
    "respect/validation": "^2.4",
    "symfony/cache": "^7.4",
    "symfony/console": "^7.4",
    "symfony/var-exporter": "7.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Espresso\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
